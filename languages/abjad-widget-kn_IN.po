msgstr ""
"ಸ್ವಾಗತ! ನೀವು ಈ ಪ್ಯಾನೆಲ್‌ನಿಂದ ವಿಜೆಟ್ ಸುದ್ದಿಗಳು ಮತ್ತು ಘೋಷಣೆಗಳನ್ನು "
"ಅನುಸರಿಸಬಹುದು."

msgid "Widget Settings"
msgstr "ವಿಜೆಟ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು"

msgid "Widget Status"
msgstr "ವಿಜೆಟ್ ಸ್ಥಿತಿ"

msgid "Widget active"
msgstr "ವಿಜೆಟ್ ಸಕ್ರಿಯ"

msgid ""
"Wrong JavaScript code may break the widget. Backup before making changes."
msgstr ""
"ತಪ್ಪಾದ ಜಾವಾಸ್ಕ್ರಿಪ್ಟ್ ಕೋಡ್ ವಿಜೆಟ್ ಅನ್ನು ಹಾಳು ಮಾಡಬಹುದು. ಬದಲಾವಣೆಗಳ ಮುನ್ನ "
"ಬ್ಯಾಕ್ಅಪ್ ಮಾಡಿಕೊಳ್ಳಿ."

msgid "Your Buy Me a Coffee username"
msgstr "ನಿಮ್ಮ Buy Me a Coffee ಬಳಕೆದಾರ ಹೆಸರು"

msgid ""
"Your changes will directly affect the widget appearance. If you don't know "
"CSS, it's recommended to use default settings."
msgstr ""
"ನಿಮ್ಮ ಬದಲಾವಣೆಗಳು ನೇರವಾಗಿ ವಿಜೆಟ್ ಕಾಣಿಕೆಯ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುತ್ತವೆ. ನೀವು CSS "
"ತಿಳಿಯದಿದ್ದರೆ, ಡೀಫಾಲ್ಟ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬಳಸುವುದು ಶಿಫಾರಸು."

msgid "Abjad Widget - Local Dashboard"
msgstr "ಅಬ್ಜಾದ್ ವಿಜೆಟ್ - ಸ್ಥಳೀಯ ಡ್ಯಾಶ್ಬೋರ್ಡ್"

msgid "Spiritual Seekers and Mystics"
msgstr "ಆಧ್ಯಾತ್ಮಿಕ ಹುಡುಕುವವರು ಮತ್ತು ರಹಸ್ಯಜ್ಞರು"

msgid ""
"Personality Traits: Curious, introspective, open-minded, and drawn to "
"esoteric knowledge. They may have a strong interest in uncovering hidden "
"meanings or patterns in life. Occupations: Spiritual coaches, tarot readers,"
" astrologers, or individuals involved in New Age practices. Ideological "
"Spectrum: Likely to lean toward spiritual or metaphysical beliefs. They may "
"see the tools as a way to connect with deeper truths or universal energies."
msgstr ""
"Personality Traits: ಕುತೂಹಲ, ಒಳನೋಟದ, ಮುಕ್ತಮನಸ್ಸಿನ, ಮತ್ತು ರಹಸ್ಯಜ್ಞಾನದತ್ತ "
"ಆಕರ್ಷಿತರಾದವರು. ಅವರು ಜೀವನದ ಅಡಗಿದ ಅರ್ಥಗಳು ಅಥವಾ ಮಾದರಿಗಳನ್ನು ಪತ್ತೆಹಚ್ಚುವಲ್ಲಿ ಗಾಢ"
" ಆಸಕ್ತಿ ಹೊಂದಿರಬಹುದು. ವೃತ್ತಿಗಳು: ಆಧ್ಯಾತ್ಮಿಕ ಕೋಚ್‌ಗಳು, ಟ್ಯಾರೋ ಓದುಗರ, "
"ಜ್ಯೋತಿಷಿಗಳು, ಅಥವಾ ನ್ಯೂ ಏಜ್ ಅಭ್ಯಾಸಗಳಲ್ಲಿ ಭಾಗವಹಿಸುವ ವ್ಯಕ್ತಿಗಳು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ"
" ಸ್ಪೆಕ್ಟ್ರಂ: ಆಧ್ಯಾತ್ಮಿಕ ಅಥವಾ ಮೇಟಾಫಿಸಿಕಲ್ ನಂಬಿಕೆಗಳತ್ತ ಭಾವಿಸುವ ಸಾಧ್ಯತೆ. ಅವರು "
"ಸಾಧನಗಳನ್ನು ಆಳವಾದ ಸತ್ಯಗಳೊಂದಿಗೆ ಅಥವಾ ವಿಶ್ವ ಶಕ್ತಿಗಳೊಂದಿಗೆ ಸಂಪರ್ಕಿಸುವ ಮಾರ್ಗವೆಂದು"
" ಕಾಣಬಹುದು."

msgid "Numerologists and Gematria Enthusiasts"
msgstr "ಸಂಖ್ಯಾಶಾಸ್ತ್ರಜ್ಞರು ಮತ್ತು ಜೆಮ್ಯಾಟ್ರಿಯಾ ಪ್ರೇಮಿಗಳು"

msgid ""
"Personality Traits: Analytical, detail-oriented, and fascinated by the "
"relationship between numbers and language. They may enjoy decoding symbolic "
"meanings. Occupations: Freelance numerologists, writers on esoteric topics, "
"or hobbyists exploring numerology. Ideological Spectrum: May range from "
"those who view numerology as a fun intellectual exercise to those who "
"believe in its profound spiritual significance."
msgstr ""
"Personality Traits: ವಿಶ್ಲೇಷಣಾತ್ಮಕ, ವಿವರಕೇಂದ್ರೀಕೃತ, ಮತ್ತು ಸಂಖ್ಯೆಗಳು ಮತ್ತು "
"ಭಾಷೆಯ ನಡುವಿನ ಸಂಬಂಧದ ಮೇಲೆ ಆಕರ್ಷಿತರಾದವರು. ಅವರು ಚಿಹ್ನಾತ್ಮಕ ಅರ್ಥಗಳ ಡಿಕೋಡ್ "
"ಮಾಡುವಲ್ಲಿ ಆನಂದಿಸಬಹುದು. ವೃತ್ತಿಗಳು: ಫ್ರೀಲ್ಯಾನ್ಸ್ ಸಂಖ್ಯಾಶಾಸ್ತ್ರಜ್ಞರು, ರಹಸ್ಯ "
"ವಿಷಯಗಳ ಲೇಖಕರು, ಅಥವಾ ಸಂಖ್ಯಾಶಾಸ್ತ್ರವನ್ನು ಅನ್ವೇಷಿಸುವ ಹವ್ಯಾಸಿಗಳು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ"
" ಸ್ಪೆಕ್ಟ್ರಂ: ಸಂಖ್ಯಾಶಾಸ್ತ್ರವನ್ನು ಮನರಂಜನೆಯ ಬೌದ್ಧಿಕ ವ್ಯಾಯಾಮವಾಗಿ ನೋಡುವವರಿಂದ ಅದರ "
"ಆಳವಾದ ಆಧ್ಯಾತ್ಮಿಕ ಮಹತ್ವವನ್ನು ನಂಬುವವರವರೆಗೆ ವ್ಯಾಪಿಸಬಹುದು."

msgid "Historians and Linguists"
msgstr "ಇತಿಹಾಸಕಾರರು ಮತ್ತು ಭಾಷಾಶಾಸ್ತ್ರಜ್ಞರು"

msgid ""
"Personality Traits: Scholarly, methodical, and interested in historical or "
"cultural contexts of numerical systems like Abjad. Occupations: Academics, "
"researchers, or students studying Middle Eastern languages, history, or "
"religious texts. Ideological Spectrum: Likely to approach the tools from a "
"secular, academic perspective, focusing on their historical or linguistic "
"significance."
msgstr ""
"Personality Traits: ಪಂಡಿತ, ವಿಧಾನಬದ್ಧ, ಮತ್ತು ಅಬ್ಜಾದ್ ಹಾಗು ಇತರ ಸಂಖ್ಯಾತ್ಮಕ "
"ವ್ಯವಸ್ಥೆಗಳ ಐತಿಹಾಸಿಕ ಅಥವಾ ಸಂಸ್ಕೃತಿಕ ಸಂದರ್ಭಗಳಲ್ಲಿ ಆಸಕ್ತಿ ಹೊಂದಿರುವವರು. "
"ವೃತ್ತಿಗಳು: ವಿದ್ಯಾವಂತರ, ಸಂಶೋಧಕರು, ಅಥವಾ ಮಧ್ಯಪೂರ್ವ ಭಾಷೆಗಳು, ಇತಿಹಾಸ, ಅಥವಾ "
"ಧಾರ್ಮಿಕ ಪಠ್ಯಗಳನ್ನು ಅಧ್ಯಯನ ಮಾಡುವ ವಿದ್ಯಾರ್ಥಿಗಳು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ ಸ್ಪೆಕ್ಟ್ರಂ: "
"ಸಾಧನಗಳನ್ನು ಧರ್ಮನಿರಪೇಕ್ಷ, ಅಕಾಡೆಮಿಕ್ ದೃಷ್ಟಿಯಿಂದ ನೋಡುವ ಸಾಧ್ಯತೆ, ಅವುಗಳ ಐತಿಹಾಸಿಕ "
"ಅಥವಾ ಭಾಷಾತ್ಮಕ ಮಹತ್ವದ ಮೇಲೆ ಗಮನ ನೀಡುವರು."

msgid "Religious or Faith-Based Individuals"
msgstr "ಧಾರ್ಮಿಕ ಅಥವಾ ನಂಬಿಕೆ ಆಧಾರಿತ ವ್ಯಕ್ತಿಗಳು"

msgid ""
"Personality Traits: Devout, reflective, and seeking deeper connections to "
"their faith. They may use the tools to explore religious texts or divine "
"messages. Occupations: Religious scholars, imams, priests, or laypeople with"
" a strong interest in their faith’s mystical traditions. Ideological "
"Spectrum: Likely to have a traditional or conservative worldview, using the "
"tools to reinforce their spiritual beliefs."
msgstr ""
"Personality Traits: ಭಕ್ತ, ಚಿಂತಕ, ಮತ್ತು ತಮ್ಮ ನಂಬಿಕೆಗೆ ಆಳವಾದ ಸಂಪರ್ಕವನ್ನು "
"ಹುಡುಕುವವರು. ಅವರು ಧಾರ್ಮಿಕ ಪಠ್ಯಗಳು ಅಥವಾ ದಿವ್ಯ ಸಂದೇಶಗಳನ್ನು ಅನ್ವೇಷಿಸಲು "
"ಸಾಧನಗಳನ್ನು ಬಳಸಬಹುದು. ವೃತ್ತಿಗಳು: ಧಾರ್ಮಿಕ ಪಂಡಿತರು, ಇಮಾಮರು, ಪಾದ್ರಿಗಳು, ಅಥವಾ "
"ತಮ್ಮ ನಂಬಿಕೆಯ ರಹಸ್ಯ ಪರಂಪರೆಗೆ ಗಾಢ ಆಸಕ್ತಿ ಹೊಂದಿರುವ ಸಾಮಾನ್ಯ ಜನರು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ"
" ಸ್ಪೆಕ್ಟ್ರಂ: ಸಂಪ್ರದಾಯಬದ್ಧ ಅಥವಾ ಸಂರಕ್ಷಣಾತ್ಮಕ ಜಗತ್ತಿನ ದೃಷ್ಟಿಕೋಣ ಹೊಂದಿದ್ದು, "
"ಸಾಧನಗಳನ್ನು ತಮ್ಮ ಆಧ್ಯಾತ್ಮಿಕ ನಂಬಿಕೆಗಳನ್ನು ಬಲಪಡಿಸಲು ಬಳಸುತ್ತಾರೆ."

msgid "Writers and Artists"
msgstr "ಲೇಖಕರು ಮತ್ತು ಕಲಾವಿದರು"

msgid ""
"Personality Traits: Creative, imaginative, and drawn to symbolic or abstract"
" concepts. They may use the tools for inspiration or to add layers of "
"meaning to their work. Occupations: Authors, poets, visual artists, or "
"musicians. Ideological Spectrum: May range from secular creatives to those "
"with a spiritual or mystical bent."
msgstr ""
"Personality Traits: ಸೃಜನಾತ್ಮಕ, ಕಲ್ಪನಾಶೀಲ, ಮತ್ತು ಚಿಹ್ನಾತ್ಮಕ ಅಥವಾ ಅಮೂರ್ತ "
"ಕಲ್ಪನೆಗಳತ್ತ ಆಕರ್ಷಿತರಾದವರು. ಅವರು ಪ್ರೇರಣೆಗಾಗಿ ಅಥವಾ ತಮ್ಮ ಕಾರ್ಯಕ್ಕೆ ಅರ್ಥದ "
"ಪದರಗಳನ್ನು ಸೇರಿಸಲು ಸಾಧನಗಳನ್ನು ಬಳಸಬಹುದು. ವೃತ್ತಿಗಳು: ಲೇಖಕರು, ಕವಿಗಳು, "
"ದೃಶ್ಯಕಲಾವಿದರು, ಅಥವಾ ಸಂಗೀತಗಾರರು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ ಸ್ಪೆಕ್ಟ್ರಂ: ಧರ್ಮನಿರಪೇಕ್ಷ "
"ಸೃಜನಶೀಲರಿಂದ ಆಧ್ಯಾತ್ಮಿಕ ಅಥವಾ ರಹಸ್ಯಜ್ಞಾನದ ಮನೋಭಾವದವರವರೆಗೆ ವ್ಯತ್ಯಾಸವಾಗಬಹುದು."

msgid "Puzzle and Riddle Enthusiasts"
msgstr "ಪಜಲ್ ಮತ್ತು ರಿಡಲ್ ಪ್ರೇಮಿಗಳು"

msgid ""
"Personality Traits: Playful, intellectually curious, and enjoy solving "
"complex problems or decoding patterns. Occupations: Hobbyists, puzzle "
"designers, or educators. Ideological Spectrum: Likely to approach the tools "
"as a form of entertainment or mental exercise, with little ideological "
"attachment."
msgstr ""
"Personality Traits: ಆಟವಾಡುವ, ಬೌದ್ಧಿಕ ಕುತೂಹಲ ಹೊಂದಿರುವ, ಮತ್ತು ಸಂಕೀರ್ಣ "
"ಸಮಸ್ಯೆಗಳನ್ನು ಪರಿಹರಿಸುವುದು ಅಥವಾ ಮಾದರಿಗಳನ್ನು ಡಿಕೋಡ್ ಮಾಡುವುದರಲ್ಲಿ ಆನಂದಿಸುವವರು. "
"ವೃತ್ತಿಗಳು: ಹವ್ಯಾಸಿಗಳು, ಪಜಲ್ ವಿನ್ಯಾಸಗಾರರು, ಅಥವಾ ಶಿಕ್ಷಕರು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ "
"ಸ್ಪೆಕ್ಟ್ರಂ: ಸಾಧನಗಳನ್ನು ಮನರಂಜನೆ ಅಥವಾ ಮಾನಸಿಕ ವ್ಯಾಯಾಮವೆಂದು ನೋಡುವ ಸಾಧ್ಯತೆ, ಕಡಿಮೆ"
" ಆದರ್ಶಶಾಸ್ತ್ರೀಯ ಬದ್ಧತೆ."

msgid "Conspiracy Theorists and Alternative Thinkers"
msgstr "ಸಂಯೋಜನಾ ಸಿದ್ಧಾಂತಜ್ಞರು ಮತ್ತು ಪರ್ಯಾಯ ಚಿಂತಕರು"

msgid ""
"Personality Traits: Skeptical of mainstream narratives, drawn to uncovering "
"hidden truths or patterns in systems. Occupations: Independent researchers, "
"bloggers, or activists. Ideological Spectrum: May have a more radical or "
"unconventional worldview, using the tools to support alternative theories or"
" narratives."
msgstr ""
"Personality Traits: ಪ್ರಧಾನ ಕಥಾನಕಗಳ ಬಗ್ಗೆ ಅನುಮಾನಕಾರಿ, ವ್ಯವಸ್ಥೆಗಳಲ್ಲಿನ ಅಡಗಿದ "
"ಸತ್ಯಗಳು ಅಥವಾ ಮಾದರಿಗಳನ್ನು ಪತ್ತೆಹಚ್ಚುವಲ್ಲಿ ಆಕರ್ಷಿತರಾದವರು. ವೃತ್ತಿಗಳು: ಸ್ವತಂತ್ರ "
"ಸಂಶೋಧಕರು, ಬ್ಲಾಗರ್‌ಗಳು, ಅಥವಾ ಕ್ರಿಯಾಶೀಲರು. ಆದರ್ಶಶಾಸ್ತ್ರೀಯ ಸ್ಪೆಕ್ಟ್ರಂ: ಹೆಚ್ಚು "
"ರ‍್ಯಾಡಿಕಲ್ ಅಥವಾ ಅನೌಪಚಾರಿಕ ಜಗತ್ತಿನ ದೃಷ್ಟಿಕೋಣ ಹೊಂದಿದ್ದು, ಸಾಧನಗಳನ್ನು ಪರ್ಯಾಯ "
"ಸಿದ್ಧಾಂತಗಳು ಅಥವಾ ಕಥಾನಕಗಳಿಗೆ ಬೆಂಬಲಿಸಲು ಬಳಸುತ್ತಾರೆ."

msgid "☕ Support the Project"
msgstr "☕ ಯೋಜನೆಯನ್ನು ಬೆಂಬಲಿಸಿ"

msgid "If you like my project, you can buy me a coffee!"
msgstr "ನಿಮಗೆ ನನ್ನ ಯೋಜನೆ ಇಷ್ಟವಾಗಿದ್ದರೆ, ನೀವು ನನಗೆ ಕಾಫಿ ಖರೀದಿಸಬಹುದು!"

msgid "Buy Me A Coffee"
